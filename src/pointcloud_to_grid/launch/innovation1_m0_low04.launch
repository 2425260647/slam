<launch>
  <arg name="bag" default="$(env HOME)/slam_ws/paper_exp/bags/mapping_01.bag"/>
  <arg name="rate" default="0.5"/>
  <arg name="output_prefix" default="$(env HOME)/slam_ws/paper_exp/maps/mapping_01/M0_projection_optimized_low04/my_map"/>
  <arg name="min_runtime" default="180.0"/>
  <arg name="settle_seconds" default="10.0"/>
  <arg name="check_period" default="1.0"/>

  <param name="/use_sim_time" value="true"/>

  <node pkg="tf2_ros" type="static_transform_publisher" name="base_to_laser"
        args="0 0 0.4 -1.5708 0 0 base_link laser_link"/>

  <node pkg="pointcloud_to_grid" type="pointcloud_projection_optimizer.py"
        name="pointcloud_projection_optimizer" output="screen">
    <param name="input_topic" value="/velodyne_points"/>
    <param name="output_topic" value="/velodyne_points_optimized"/>
    <param name="z_ground_band" value="0.04"/>
    <param name="z_obstacle_min" value="0.04"/>
    <param name="z_obstacle_max" value="1.60"/>
    <param name="z_ground_percentile" value="10.0"/>
    <param name="voxel_leaf_xy" value="0.05"/>
    <param name="voxel_leaf_z" value="0.10"/>
    <param name="min_points_per_voxel" value="2"/>
  </node>

  <node pkg="pointcloud_to_laserscan" type="pointcloud_to_laserscan_node"
        name="cloud_to_scan" output="screen">
    <remap from="cloud_in" to="/velodyne_points_optimized"/>
    <remap from="scan"     to="/scan"/>
    <param name="target_frame"        value="laser_link"/>
    <param name="transform_tolerance" value="0.05"/>
    <param name="min_height"          value="-0.35"/>
    <param name="max_height"          value="1.6"/>
    <param name="angle_min"           value="-3.14159"/>
    <param name="angle_max"           value="3.14159"/>
    <param name="angle_increment"     value="0.00436"/>
    <param name="scan_time"           value="0.1"/>
    <param name="range_min"           value="0.30"/>
    <param name="range_max"           value="25.0"/>
  </node>

  <node pkg="hector_mapping" type="hector_mapping" name="hector_mapping" output="screen">
    <param name="map_resolution"              value="0.05"/>
    <param name="map_size"                    value="512"/>
    <param name="map_start_x"                value="0.5"/>
    <param name="map_start_y"                value="0.5"/>
    <param name="map_frame"                  value="map"/>
    <param name="base_frame"                 value="base_link"/>
    <param name="odom_frame"                 value="odom"/>
    <param name="scan_topic"                 value="/scan"/>
    <param name="use_tf_scan_transformation" value="true"/>
    <param name="use_tf_pose_start_estimate" value="false"/>
    <param name="pub_map_odom_transform"     value="true"/>
    <param name="map_update_distance_thresh" value="0.10"/>
    <param name="map_update_angle_thresh"    value="0.08"/>
    <param name="laser_min_dist"             value="0.30"/>
    <param name="laser_max_dist"             value="25.0"/>
  </node>

  <node pkg="rosbag" type="play" name="bag_play" output="screen" required="true"
        args="--clock -r $(arg rate) $(arg bag) --topics /velodyne_points /tf /tf_static"/>

  <node pkg="pointcloud_to_grid" type="save_stable_map.py"
        name="stable_map_saver" output="screen">
    <param name="map_topic" value="/map"/>
    <param name="output_prefix" value="$(arg output_prefix)"/>
    <param name="min_runtime" value="$(arg min_runtime)"/>
    <param name="settle_seconds" value="$(arg settle_seconds)"/>
    <param name="check_period" value="$(arg check_period)"/>
    <param name="min_known_ratio" value="0.05"/>
  </node>
</launch>
