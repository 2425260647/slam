<launch>
    <!-- 0. Static TF: base_link -> laser_link (0.4m above, rotated -90deg yaw) -->
    <node pkg="tf2_ros" type="static_transform_publisher"
        name="base_to_laser"
        args="0 0 0.4 -1.5708 0 0 base_link laser_link"/>

    <!-- 1. Map server -->
    <node pkg="map_server" type="map_server" name="map_server" output="screen"
        args="$(find my_navigation)/maps/my_map.yaml">
        <param name="frame_id" value="map"/>
    </node>

    <!-- 2. 3D point cloud -> 2D laser scan -->
    <node pkg="pointcloud_to_laserscan" type="pointcloud_to_laserscan_node"
          name="cloud_to_scan" output="screen">
        <remap from="cloud_in" to="/velodyne_points"/>
        <remap from="scan" to="/scan"/>
        <param name="target_frame" value="laser_link"/>
        <param name="transform_tolerance" value="0.01"/>
        <param name="min_height" value="-0.35"/>
        <param name="max_height" value="1.6"/>
        <param name="angle_min" value="-3.14159"/>
        <param name="angle_max" value="3.14159"/>
        <param name="angle_increment" value="0.00436"/>
        <param name="scan_time" value="0.1"/>
        <param name="range_min" value="0.30"/>
        <param name="range_max" value="30.0"/>
    </node>

    <!-- 3. AMCL localization -->
    <node pkg="amcl" type="amcl" name="amcl" output="screen">
        <remap from="scan" to="/scan"/>
        <param name="initial_pose_x" value="0"/>
        <param name="initial_pose_y" value="0"/>
        <param name="initial_pose_a" value="0.0"/>
        <param name="initial_cov_xx" value="0.12"/>
        <param name="initial_cov_yy" value="0.12"/>
        <param name="initial_cov_aa" value="0.04"/>
        <param name="laser_model_type" value="likelihood_field"/>
        <param name="laser_likelihood_max_dist" value="1.5"/>
        <param name="laser_max_beams" value="90"/>
        <param name="odom_model_type" value="diff"/>
        <param name="odom_alpha1" value="0.2"/>
        <param name="odom_alpha2" value="0.2"/>
        <param name="odom_alpha3" value="0.2"/>
        <param name="odom_alpha4" value="0.2"/>
        <param name="min_particles" value="800"/>
        <param name="max_particles" value="3500"/>
        <param name="update_min_d" value="0.03"/>
        <param name="update_min_a" value="0.035"/>
        <param name="tf_broadcast" value="true"/>
        <param name="transform_tolerance" value="0.1"/>
    </node>

    <!-- 4. Dynamic obstacle detector -->
    <node pkg="my_navigation" type="obstacle_detector" name="obstacle_detector" output="screen">
        <param name="laser_mount_yaw_deg" value="-90"/>
        <param name="dynamic_angle_deg" value="150"/>
        <param name="distance_threshold" value="0.6"/>
        <param name="min_cluster_points" value="15"/>
        <param name="cluster_tolerance" value="0.15"/>
        <param name="enter_frames" value="2"/>
        <param name="exit_frames" value="5"/>
        <param name="laser_frame" value="laser_link"/>
        <param name="base_frame" value="base_link"/>
        <param name="local_map_size" value="2.0"/>
        <param name="local_map_res" value="0.05"/>
        <param name="map_wait_timeout" value="10.0"/>
        <param name="localization_unknown_ratio_threshold" value="0.8"/>
        <param name="angle_offset_deg" value="0"/>
        <!-- camera_frame reuses base_link (no separate camera TF) -->
        <param name="object_max_range" value="2.0"/>
        <param name="object_fov_half_deg" value="30.0"/>
        <param name="object_projection_start_range" value="0.45"/>
        <param name="object_x_is_range" value="false"/>
        <param name="camera_frame" value="base_link"/>
        <param name="health_report_interval" value="1.0"/>
        <param name="manual_pose_report_interval" value="1.0"/>
        <param name="tx_summary_interval" value="2.0"/>
        <param name="max_scan_age" value="1.0"/>
        <param name="max_scan_future_age" value="0.20"/>
        <param name="tf_latest_fallback_age" value="0.75"/>
        <param name="include_static_map_in_local_map" value="false"/>
        <!-- Corner filter: disabled to avoid false obstacles on noisy walls -->
        <param name="enable_corner_filter"   value="false"/>
        <param name="corner_threshold"       value="0.20"/>
        <param name="corner_window"          value="2"/>
        <param name="noise_min_range"        value="0.30"/>
        <param name="noise_search_radius"    value="0.25"/>
        <param name="noise_min_neighbors"    value="2"/>
        <param name="local_map_dilate_cells" value="0"/>
    </node>

    <!-- 5. Scan-to-map pose corrector -->
    <node pkg="my_navigation" type="amcl_corrector" name="amcl_corrector" output="screen">
        <param name="laser_frame"           value="laser_link"/>
        <param name="search_radius_xy"      value="0.30"/>
        <param name="search_radius_yaw_deg" value="15.0"/>
        <param name="xy_step"               value="0.05"/>
        <param name="yaw_step_deg"          value="2.0"/>
        <param name="min_correction_dist"   value="0.08"/>
        <param name="min_scan_score"        value="0.30"/>
        <param name="check_interval"        value="15.0"/>
        <param name="covariance_trigger"    value="0.08"/>
        <param name="cooldown_time"         value="30.0"/>
        <param name="max_correction_dist"   value="0.25"/>
    </node>

    <!-- 6. Autonomous exploration controller -->
    <node pkg="search_explorer" type="explorer_controller" name="explorer_controller" output="screen">
        <!-- Motion limits -->
        <param name="max_linear_speed"           value="0.13"/>
        <param name="max_angular_speed"          value="0.50"/>
        <param name="goal_tolerance"             value="0.30"/>
        <param name="lookahead_distance"         value="0.50"/>
        <param name="path_replan_threshold"      value="1.00"/>
        <param name="dynamic_clear_time"         value="3.0"/>
        <param name="inflation_radius"           value="0.55"/>
        <param name="route_safety_radius"        value="0.50"/>
        <param name="coverage_range"             value="2.0"/>
        <param name="coverage_half_angle_deg"    value="30.0"/>
        <!-- Alignment -->
        <param name="align_angular_speed"        value="0.40"/>
        <!-- Edge-following route -->
        <param name="route_waypoint_spacing"     value="0.6"/>
        <param name="route_offset_distance"      value="0.75"/>
        <param name="route_deviation_interval"   value="4"/>
        <param name="route_max_deviation_deg"    value="15.0"/>
        <param name="use_edge_route"             value="true"/>
        <param name="edge_preferred_center_distance" value="0.70"/>
        <param name="edge_min_center_distance"   value="0.60"/>
        <param name="edge_max_center_distance"   value="0.85"/>
        <param name="edge_side_clearance"        value="0.22"/>
        <param name="edge_offset_tolerance"      value="0.12"/>
        <param name="min_static_obstacle_cluster_cells" value="12"/>
        <param name="edge_reachable_search_window" value="16"/>
        <param name="object_standoff_distance"   value="0.50"/>
        <!-- Startup gate -->
        <param name="require_local_map_before_navigation" value="false"/>
        <param name="startup_gate_enabled"       value="true"/>
        <param name="startup_stable_duration"    value="1.0"/>
        <param name="startup_scan_max_age"       value="1.0"/>
        <param name="startup_pose_max_age"       value="6.0"/>
        <param name="startup_local_map_max_age"  value="1.5"/>
        <param name="startup_min_pose_messages"  value="1"/>
        <param name="laser_front_angle_deg"      value="90.0"/>
        <param name="front_block_replan_delay"   value="1.8"/>
        <param name="front_block_skip_count"     value="3"/>
        <!-- Coverage thresholds -->
        <param name="waypoint_coverage_radius"   value="2.0"/>
        <param name="scan_coverage_target"       value="0.80"/>
        <!-- Diagnostics -->
        <param name="health_report_interval"     value="2.0"/>
        <param name="phase1_static_global_only"  value="true"/>
        <param name="startup_require_clear_warning" value="false"/>
    </node>
</launch>
