<launch>
  <node pkg="search_explorer" type="explorer_controller" name="explorer_controller" output="screen">
    <param name="max_linear_speed" value="0.13"/>
    <param name="max_angular_speed" value="0.5"/>
    <param name="goal_tolerance" value="0.3"/>
    <param name="lookahead_distance" value="0.5"/>
    <param name="inflation_radius" value="0.55"/>
    <param name="route_safety_radius" value="0.55"/>
    <param name="coverage_range" value="2.0"/>
    <param name="coverage_half_angle_deg" value="30.0"/>
    <param name="use_edge_route" value="true"/>
    <param name="route_waypoint_spacing" value="0.6"/>
    <param name="edge_preferred_center_distance" value="0.75"/>
    <param name="edge_min_center_distance" value="0.60"/>
    <param name="edge_max_center_distance" value="0.85"/>
    <param name="edge_side_clearance" value="0.22"/>
    <param name="edge_offset_tolerance" value="0.12"/>
    <param name="min_static_obstacle_cluster_cells" value="12"/>
    <param name="edge_reachable_search_window" value="16"/>
    <param name="object_standoff_distance" value="0.50"/>
    <param name="require_local_map_before_navigation" value="false"/>
    <param name="startup_gate_enabled" value="true"/>
    <param name="startup_stable_duration" value="1.0"/>
    <param name="startup_scan_max_age" value="1.0"/>
    <param name="startup_pose_max_age" value="6.0"/>
    <param name="startup_local_map_max_age" value="1.5"/>
    <param name="laser_front_angle_deg" value="90.0"/>
    <param name="front_block_replan_delay" value="1.8"/>
    <param name="front_block_skip_count" value="2"/>
    <param name="startup_min_pose_messages" value="1"/>
    <param name="health_report_interval" value="2.0"/>
    <param name="phase1_static_global_only" value="true"/>
    <param name="enable_object_goal" value="true"/>
    <param name="startup_require_clear_warning" value="false"/>
  </node>
</launch>
